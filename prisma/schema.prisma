generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  demand
  recovery
  neutral
  mixed
}

enum TaskType {
  deep_work
  problem_solving
  reading
  writing
  admin
  social_interpersonal
  errands_logistics
}

enum TaskStatus {
  active
  completed
  archived
}

enum RecommendationType {
  today_focus
  start_early
  fragmented_fit
  overload_warning
  recovery_note
  deep_work_shortage
}

enum RecommendationStatus {
  active
  useful
  dismissed
}

enum RecommendationFeedbackValue {
  useful
  not_useful
}

model User {
  id                String                   @id @default(cuid())
  name              String?
  email             String?                  @unique
  emailVerified     DateTime?
  image             String?
  includedGoogleCalendarIds String[]         @default([])
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  accounts          Account[]
  sessions          Session[]
  workProfile       WorkProfile?
  calendarEvents    CalendarEvent[]
  tasks             Task[]
  recommendations   Recommendation[]
  feedback          RecommendationFeedback[]
  syncLogs          SyncLog[]
  weekAnalysisReport WeekAnalysisReport?
  weekAnalysisHistory WeekAnalysisHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  refresh_token_expires_in Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  updatedAt         DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WorkProfile {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  rawAnswers                  Json?
  modelVersion                String?
  blockNeed                   Int?
  fragmentationCost           Int?
  switchingCost               Int?
  setupLoad                   Int?
  socialSpillover             Int?
  passiveReset                Int?
  socialReset                 Int?
  physicalReset               Int?
  overcommitmentRisk          Int?
  subtypeName                 String?
  subtypeDescription          String?
  shortSummary                String?
  overloadSensitivity         Int?
  transitionCost              Int?
  deepWorkCapacity            Int?
  ambiguityTolerance          Int?
  routinePreference           Int?
  socialRecoveryValue         Int?
  exerciseRecoveryValue       Int?
  quietRecoveryValue          Int?
  preferredRecoveryModes      String[] @default([])
  riskFlags                   String[] @default([])
  deepWorkPreference          Int
  fragmentationSensitivity    Int
  socialLoadCost              Int
  ambiguityFriction           Int
  exerciseRecoveryBenefit     Int
  socialRecoveryBenefit       Int
  prefersLongBlocks           Boolean  @default(false)
  underestimatesOpenEndedWork Boolean  @default(false)
  quizVersion                 String
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id               String    @id @default(cuid())
  userId           String
  externalId       String
  title            String
  startTime        DateTime
  endTime          DateTime
  allDay           Boolean   @default(false)
  source           String
  inferredType     EventType
  userOverrideType EventType?
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([userId, startTime])
}

model Task {
  id                         String     @id @default(cuid())
  userId                     String
  title                      String
  dueAt                      DateTime
  estimatedHours             Decimal    @db.Decimal(4, 2)
  taskType                   TaskType
  projectLabel               String?
  notes                      String?
  subtasks                   Json?
  ambiguityLevel             Int?
  emotionalFriction          Int?
  requiresUninterruptedBlock Boolean    @default(false)
  status                     TaskStatus @default(active)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@index([userId, dueAt])
}

model Recommendation {
  id                 String                @id @default(cuid())
  userId             String
  taskId             String?
  date               DateTime
  recommendationType RecommendationType
  summary            String
  explanation        String
  score              Int
  suggestedStart     DateTime?
  suggestedEnd       DateTime?
  status             RecommendationStatus @default(active)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?                    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  feedback  RecommendationFeedback[]

  @@index([userId, date])
}

model RecommendationFeedback {
  id               String                      @id @default(cuid())
  userId           String
  recommendationId String
  value            RecommendationFeedbackValue
  createdAt        DateTime                    @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([userId, recommendationId])
}

model SyncLog {
  id           String   @id @default(cuid())
  userId       String
  source       String
  status       String
  itemCount    Int      @default(0)
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeekAnalysisReport {
  id           String   @id @default(cuid())
  userId       String   @unique
  analyzedAt   DateTime
  expiresAt    DateTime
  observations String[] @default([])
  suggestions  String[] @default([])
  classifiedEvents Json?
  derivedMetrics   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeekAnalysisHistory {
  id             String   @id @default(cuid())
  userId         String
  weekStart      DateTime
  weekEnd        DateTime
  analyzedAt     DateTime
  overallLoadScore Int
  observations   String[] @default([])
  suggestions    String[] @default([])
  derivedMetrics Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, analyzedAt])
}
